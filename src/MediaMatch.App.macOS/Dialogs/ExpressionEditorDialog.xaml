<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog
    x:Class="MediaMatch.App.macOS.Dialogs.ExpressionEditorDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="ThisDialog"
    Title="Expression Editor"
    CloseButtonText="Cancel"
    DefaultButton="Primary"
    PrimaryButtonText="Apply"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="600">
    <StackPanel MinWidth="560" Spacing="16">

        <!-- Example expressions -->
        <StackPanel Spacing="4">
            <TextBlock
                Style="{StaticResource CaptionTextBlockStyle}"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="Templates" />
            <ComboBox
                x:Name="ExamplesComboBox"
                HorizontalAlignment="Stretch"
                DisplayMemberPath="Name"
                ItemsSource="{Binding ViewModel.ExampleExpressions, ElementName=ThisDialog}"
                SelectedItem="{Binding ViewModel.SelectedExample, Mode=TwoWay, ElementName=ThisDialog}"
                AutomationProperties.Name="Expression templates" />
        </StackPanel>

        <!-- Expression input -->
        <StackPanel Spacing="4">
            <TextBlock
                Style="{StaticResource CaptionTextBlockStyle}"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="Expression" />
            <TextBox
                x:Name="ExpressionTextBox"
                MinHeight="80"
                AcceptsReturn="True"
                FontFamily="Cascadia Code, Consolas, Menlo, Courier New"
                Text="{Binding ViewModel.Expression, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ElementName=ThisDialog}"
                TextWrapping="Wrap"
                SelectionChanged="ExpressionTextBox_SelectionChanged"
                AutomationProperties.Name="Expression input" />
        </StackPanel>

        <!-- Validation indicator -->
        <StackPanel x:Name="ValidationPanel" Orientation="Horizontal" Spacing="8">
            <FontIcon
                x:Name="ValidationIcon"
                FontSize="14" />
            <TextBlock
                x:Name="ValidationText"
                Style="{StaticResource CaptionTextBlockStyle}" />
        </StackPanel>

        <!-- Live preview -->
        <StackPanel Spacing="4">
            <TextBlock
                Style="{StaticResource CaptionTextBlockStyle}"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="Preview" />
            <Border
                Padding="12,8"
                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                CornerRadius="4">
                <TextBlock
                    x:Name="PreviewText"
                    FontFamily="Cascadia Code, Consolas, Menlo, Courier New"
                    IsTextSelectionEnabled="True"
                    TextWrapping="Wrap"
                    Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
            </Border>
        </StackPanel>

        <!-- Available tokens -->
        <Expander
            HorizontalAlignment="Stretch"
            HorizontalContentAlignment="Stretch"
            AutomationProperties.Name="Available tokens">
            <Expander.Header>
                <TextBlock Text="Available Tokens" />
            </Expander.Header>
            <Expander.Content>
                <ScrollViewer
                    MaxHeight="280"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto">
                <ItemsRepeater ItemsSource="{Binding ViewModel.AvailableTokens, ElementName=ThisDialog}">
                    <ItemsRepeater.Layout>
                        <UniformGridLayout
                            MinColumnSpacing="4"
                            MinRowSpacing="4"
                            MinItemWidth="160"
                            ItemsStretch="Fill" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate>
                            <Button
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Padding="8,6"
                                Click="TokenButton_Click"
                                Tag="{Binding Name}"
                                AutomationProperties.Name="{Binding Name}"
                                ToolTipService.ToolTip="{Binding Description}">
                                <StackPanel Spacing="2">
                                    <TextBlock
                                        FontFamily="Cascadia Code, Consolas, Menlo, Courier New"
                                        FontSize="12"
                                        Text="{Binding Name}" />
                                    <TextBlock
                                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                        Style="{StaticResource CaptionTextBlockStyle}"
                                        Text="{Binding Description}"
                                        TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
                </ScrollViewer>
            </Expander.Content>
        </Expander>

    </StackPanel>
    </ScrollViewer>
</ContentDialog>
