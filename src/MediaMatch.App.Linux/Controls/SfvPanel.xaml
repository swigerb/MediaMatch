<UserControl
    x:Class="MediaMatch.App.Linux.Controls.SfvPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- File list with progress bars -->
        <ListView Grid.Row="0"
                  ItemsSource="{Binding Files}"
                  Visibility="{Binding ShowEmptyState, Converter={StaticResource BoolNegationConverter}}"
                  SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="4,8" ColumnSpacing="8" RowSpacing="4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="200"/>
                        </Grid.ColumnDefinitions>

                        <FontIcon Grid.Row="0" Grid.Column="0"
                                  Glyph="{Binding StateIcon}"
                                  FontSize="14"
                                  VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="0" Grid.Column="1"
                                   Text="{Binding FileName}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="0" Grid.Column="2"
                                   Text="{Binding HashValue}"
                                   FontFamily="Consolas"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <ProgressBar Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                                     Value="{Binding Progress}"
                                     Maximum="100"
                                     Height="4"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Empty state -->
        <StackPanel Grid.Row="0"
                    Visibility="{Binding ShowEmptyState}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="12">
            <FontIcon Glyph="&#xE9D9;" FontSize="48" HorizontalAlignment="Center"
                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <TextBlock Text="No files loaded"
                       Style="{ThemeResource SubtitleTextBlockStyle}"
                       HorizontalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <HyperlinkButton Content="Load Files"
                             HorizontalAlignment="Center"
                             Command="{Binding LoadFilesCommand}"/>
        </StackPanel>

        <!-- Algorithm selection -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="16">
            <TextBlock Text="Algorithm:" VerticalAlignment="Center" FontWeight="SemiBold"/>
            <RadioButton x:Name="CRC32Radio" Content="CRC32" GroupName="Algorithm"
                         IsChecked="True" Checked="AlgorithmRadio_Checked"/>
            <RadioButton x:Name="MD5Radio" Content="MD5" GroupName="Algorithm"
                         Checked="AlgorithmRadio_Checked"/>
            <RadioButton x:Name="SHA1Radio" Content="SHA-1" GroupName="Algorithm"
                         Checked="AlgorithmRadio_Checked"/>
            <RadioButton x:Name="SHA256Radio" Content="SHA-256" GroupName="Algorithm"
                         Checked="AlgorithmRadio_Checked"/>
        </StackPanel>

        <!-- Action buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
            <Button Content="Verify All"
                    Style="{ThemeResource AccentButtonStyle}"
                    Command="{Binding VerifyAllCommand}"/>
            <Button Content="Load Files"
                    Command="{Binding LoadFilesCommand}"/>
            <Button Content="Clear"
                    Command="{Binding ClearCommand}"/>
        </StackPanel>

        <!-- Total progress -->
        <Grid Grid.Row="3" ColumnSpacing="8" Visibility="{Binding IsVerifying}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ProgressBar Grid.Column="0"
                         Value="{Binding TotalProgress}"
                         Maximum="100"/>
            <TextBlock Grid.Column="1"
                       Text="{Binding TotalProgressText}"
                       Style="{ThemeResource CaptionTextBlockStyle}"
                       VerticalAlignment="Center"/>
        </Grid>
    </Grid>
</UserControl>
