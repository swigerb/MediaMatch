<UserControl
    x:Class="MediaMatch.App.Linux.Controls.FilterPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="16" ColumnSpacing="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="1.5*"/>
        </Grid.ColumnDefinitions>

        <!-- Left: File list -->
        <Grid Grid.Column="0" RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Files" FontWeight="SemiBold"
                       Style="{ThemeResource SubtitleTextBlockStyle}"/>

            <ListView Grid.Row="1"
                      ItemsSource="{Binding Files}"
                      SelectedItem="{Binding SelectedFile, Mode=TwoWay}"
                      SelectionMode="Single">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Padding="4,6" Spacing="2">
                            <TextBlock Text="{Binding FileName}" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding FolderName}"
                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Bottom actions -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
                <Button Content="Load Files" Command="{Binding LoadFilesCommand}"/>
                <Button Content="Clear" Command="{Binding ClearCommand}"/>
            </StackPanel>
        </Grid>

        <!-- Right: Info tabs + properties -->
        <Grid Grid.Column="1" RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Tab selection via RadioButtons -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12">
                <RadioButton x:Name="MediaInfoTab" Content="Media Info" GroupName="InfoTab"
                             IsChecked="True" Checked="InfoTab_Checked"/>
                <RadioButton x:Name="AttributesTab" Content="Attributes" GroupName="InfoTab"
                             Checked="InfoTab_Checked"/>
                <RadioButton x:Name="TagsTab" Content="Tags" GroupName="InfoTab"
                             Checked="InfoTab_Checked"/>
            </StackPanel>

            <!-- Properties list -->
            <ListView Grid.Row="1"
                      ItemsSource="{Binding MediaInfoEntries}"
                      SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="4,6" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{Binding Key}"
                                       FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Value}"
                                       TextWrapping="Wrap"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Status -->
            <TextBlock Grid.Row="2"
                       Text="{Binding StatusMessage}"
                       Style="{ThemeResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </Grid>
    </Grid>
</UserControl>
