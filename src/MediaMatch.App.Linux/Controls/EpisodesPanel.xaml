<UserControl
    x:Class="MediaMatch.App.Linux.Controls.EpisodesPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Datasource selector -->
        <ComboBox Grid.Row="0"
                  Header="Datasource"
                  HorizontalAlignment="Stretch"
                  ItemsSource="{Binding DatasourceOptions}"
                  SelectedIndex="{Binding SelectedDatasourceIndex, Mode=TwoWay}"/>

        <!-- Search bar -->
        <Grid Grid.Row="1" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0"
                     PlaceholderText="Search for a show..."
                     Text="{Binding SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            <Button Grid.Column="1"
                    Content="Find"
                    Style="{ThemeResource AccentButtonStyle}"
                    Command="{Binding FindCommand}"/>
        </Grid>

        <!-- Season / Order / Language filters -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
            <ComboBox Header="Season"
                      MinWidth="120"
                      ItemsSource="{Binding SeasonOptions}"
                      SelectedIndex="{Binding SelectedSeasonIndex, Mode=TwoWay}"/>
            <ComboBox Header="Order"
                      MinWidth="120"
                      ItemsSource="{Binding OrderOptions}"
                      SelectedIndex="{Binding SelectedOrderIndex, Mode=TwoWay}"/>
            <ComboBox Header="Language"
                      MinWidth="120"
                      ItemsSource="{Binding LanguageOptions}"
                      SelectedIndex="{Binding SelectedLanguageIndex, Mode=TwoWay}"/>
        </StackPanel>

        <!-- Breadcrumb / series info -->
        <TextBlock Grid.Row="3"
                   Text="{Binding BreadcrumbText}"
                   Style="{ThemeResource CaptionTextBlockStyle}"
                   Visibility="{Binding HasEpisodes}"
                   VerticalAlignment="Top"
                   Margin="0,0,0,4"/>

        <!-- Episodes list -->
        <ListView Grid.Row="3"
                  ItemsSource="{Binding Episodes}"
                  Visibility="{Binding HasEpisodes}"
                  Margin="0,24,0,0"
                  SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding}" Padding="4,8"/>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Empty state -->
        <StackPanel Grid.Row="3"
                    Visibility="{Binding HasNoEpisodes}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="8">
            <FontIcon Glyph="&#xE8B7;" FontSize="48" HorizontalAlignment="Center"
                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <TextBlock Text="Search for a show to view episodes"
                       Style="{ThemeResource BodyTextBlockStyle}"
                       HorizontalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </StackPanel>

        <!-- Progress -->
        <ProgressRing Grid.Row="4"
                      IsActive="{Binding IsSearching}"
                      Visibility="{Binding IsSearching}"
                      Width="24" Height="24"
                      HorizontalAlignment="Left"/>

        <!-- Status -->
        <TextBlock Grid.Row="5"
                   Text="{Binding StatusMessage}"
                   Style="{ThemeResource CaptionTextBlockStyle}"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
    </Grid>
</UserControl>
