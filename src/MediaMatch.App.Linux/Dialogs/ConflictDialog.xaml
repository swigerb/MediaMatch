<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog
    x:Class="MediaMatch.App.Linux.Dialogs.ConflictDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="ThisDialog"
    Title="File Conflict"
    CloseButtonText="Cancel All"
    DefaultButton="Close"
    PrimaryButtonText="Overwrite"
    SecondaryButtonText="Skip"
    mc:Ignorable="d">

    <StackPanel MinWidth="480" Spacing="16">
        <InfoBar
            IsClosable="False"
            IsOpen="True"
            Message="The target file already exists. Choose how to proceed."
            Severity="Warning" />

        <!-- Source file info -->
        <StackPanel Spacing="4">
            <TextBlock
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Style="{StaticResource CaptionTextBlockStyle}"
                Text="Source File" />
            <TextBlock
                x:Name="SourcePathText"
                IsTextSelectionEnabled="True"
                TextWrapping="Wrap" />
            <StackPanel Orientation="Horizontal" Spacing="16">
                <TextBlock Foreground="{ThemeResource TextFillColorTertiaryBrush}">
                    <Run Text="Size:" />
                    <Run x:Name="SourceSizeRun" />
                </TextBlock>
                <TextBlock Foreground="{ThemeResource TextFillColorTertiaryBrush}">
                    <Run Text="Modified:" />
                    <Run x:Name="SourceModifiedRun" />
                </TextBlock>
            </StackPanel>
        </StackPanel>

        <!-- Target file info -->
        <StackPanel Spacing="4">
            <TextBlock
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Style="{StaticResource CaptionTextBlockStyle}"
                Text="Target File (exists)" />
            <TextBlock
                x:Name="TargetPathText"
                IsTextSelectionEnabled="True"
                TextWrapping="Wrap" />
            <StackPanel Orientation="Horizontal" Spacing="16">
                <TextBlock Foreground="{ThemeResource TextFillColorTertiaryBrush}">
                    <Run Text="Size:" />
                    <Run x:Name="TargetSizeRun" />
                </TextBlock>
                <TextBlock Foreground="{ThemeResource TextFillColorTertiaryBrush}">
                    <Run Text="Modified:" />
                    <Run x:Name="TargetModifiedRun" />
                </TextBlock>
            </StackPanel>
        </StackPanel>

        <!-- Rename option -->
        <Button
            x:Name="RenameButton"
            HorizontalAlignment="Stretch"
            Click="RenameButton_Click"
            Content="Rename (append number)" />
    </StackPanel>
</ContentDialog>
