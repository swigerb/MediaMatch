<UserControl
    x:Class="MediaMatch.App.Controls.EpisodesPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Padding="12,8">
            <ComboBox
                ItemsSource="{x:Bind ViewModel.DatasourceOptions}"
                SelectedIndex="{x:Bind ViewModel.SelectedDatasourceIndex, Mode=TwoWay}"
                AutomationProperties.Name="Datasource"
                MinWidth="140" />

            <TextBox
                Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                PlaceholderText="Search series..."
                AutomationProperties.Name="Search query"
                MinWidth="200" />

            <ComboBox
                ItemsSource="{x:Bind ViewModel.SeasonOptions}"
                SelectedIndex="{x:Bind ViewModel.SelectedSeasonIndex, Mode=TwoWay}"
                AutomationProperties.Name="Season"
                MinWidth="120" />

            <ComboBox
                ItemsSource="{x:Bind ViewModel.OrderOptions}"
                SelectedIndex="{x:Bind ViewModel.SelectedOrderIndex, Mode=TwoWay}"
                AutomationProperties.Name="Sort order"
                MinWidth="100" />

            <ComboBox
                ItemsSource="{x:Bind ViewModel.LanguageOptions}"
                SelectedIndex="{x:Bind ViewModel.SelectedLanguageIndex, Mode=TwoWay}"
                AutomationProperties.Name="Language"
                MinWidth="110" />

            <Button
                Command="{x:Bind ViewModel.FindCommand}"
                AutomationProperties.Name="Find episodes"
                Style="{ThemeResource AccentButtonStyle}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE11A;" FontSize="14" />
                    <TextBlock Text="Find" />
                </StackPanel>
            </Button>
        </StackPanel>

        <!-- Breadcrumb -->
        <TextBlock
            Grid.Row="1"
            Text="{x:Bind ViewModel.BreadcrumbText, Mode=OneWay}"
            Visibility="{x:Bind ViewModel.HasEpisodes, Mode=OneWay}"
            Style="{ThemeResource CaptionTextBlockStyle}"
            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
            Padding="12,0" />

        <!-- Episode list -->
        <Grid Grid.Row="2">
            <ListView
                ItemsSource="{x:Bind ViewModel.Episodes}"
                Visibility="{x:Bind ViewModel.HasEpisodes, Mode=OneWay}"
                SelectionMode="Extended"
                Padding="12,0"
                AutomationProperties.Name="Episodes list">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Padding="4,6">
                            <Run Text="{Binding SeriesName}" FontWeight="SemiBold" />
                            <Run Text=" - " />
                            <Run Text="{Binding Season}" />
                            <Run Text="x" />
                            <Run Text="{Binding EpisodeNumber}" />
                            <Run Text=" - " />
                            <Run Text="{Binding Title}" />
                        </TextBlock>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Empty state -->
            <StackPanel
                Visibility="{x:Bind ViewModel.HasNoEpisodes, Mode=OneWay}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="8">
                <FontIcon Glyph="&#xE8B7;" FontSize="48" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                <TextBlock
                    Text="No episodes yet. Search for a series above."
                    Style="{ThemeResource BodyTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    HorizontalAlignment="Center" />
            </StackPanel>

            <!-- Loading indicator -->
            <ProgressRing
                IsActive="{x:Bind ViewModel.IsSearching, Mode=OneWay}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Width="40" Height="40" />
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="3" Padding="12,6" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <TextBlock
                Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                Style="{ThemeResource CaptionTextBlockStyle}"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </Border>
    </Grid>
</UserControl>
