<UserControl
    x:Class="MediaMatch.App.Controls.FilterPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:MediaMatch.App.ViewModels"
    mc:Ignorable="d">

    <Grid RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Main split view: files on left, detail tabs on right -->
        <Grid Grid.Row="0" ColumnSpacing="12" Padding="12,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="200" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <!-- Left: File list grouped by folder -->
            <Border
                Grid.Column="0"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="4">
                <ListView
                    ItemsSource="{x:Bind ViewModel.Files}"
                    SelectedItem="{x:Bind ViewModel.SelectedFile, Mode=TwoWay}"
                    SelectionMode="Single"
                    AutomationProperties.Name="File list">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="vm:FilterFileItemViewModel">
                            <StackPanel Padding="4,4" Spacing="2">
                                <TextBlock
                                    Text="{x:Bind FileName, Mode=OneWay}"
                                    TextTrimming="CharacterEllipsis" />
                                <TextBlock
                                    Text="{x:Bind FolderName, Mode=OneWay}"
                                    Style="{ThemeResource CaptionTextBlockStyle}"
                                    Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>

            <!-- Right: Tabbed detail view -->
            <Border
                Grid.Column="1"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Tab header -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="0"
                                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                Padding="4,0">
                        <RadioButton Content="Archives" GroupName="FilterTab" IsChecked="True"
                            Checked="{x:Bind SetTab0}" Style="{ThemeResource DefaultRadioButtonStyle}"
                            AutomationProperties.Name="Archives tab" />
                        <RadioButton Content="Types" GroupName="FilterTab"
                            Checked="{x:Bind SetTab1}" Style="{ThemeResource DefaultRadioButtonStyle}"
                            AutomationProperties.Name="Types tab" />
                        <RadioButton Content="Parts" GroupName="FilterTab"
                            Checked="{x:Bind SetTab2}" Style="{ThemeResource DefaultRadioButtonStyle}"
                            AutomationProperties.Name="Parts tab" />
                        <RadioButton Content="Attributes" GroupName="FilterTab"
                            Checked="{x:Bind SetTab3}" Style="{ThemeResource DefaultRadioButtonStyle}"
                            AutomationProperties.Name="Attributes tab" />
                        <RadioButton Content="MediaInfo" GroupName="FilterTab"
                            Checked="{x:Bind SetTab4}" Style="{ThemeResource DefaultRadioButtonStyle}"
                            AutomationProperties.Name="MediaInfo tab" />
                    </StackPanel>

                    <!-- Tab content: MediaInfo key-value list (shown for MediaInfo tab) -->
                    <ListView
                        Grid.Row="1"
                        ItemsSource="{x:Bind ViewModel.MediaInfoEntries}"
                        SelectionMode="None"
                        Visibility="{x:Bind IsMediaInfoTab, Mode=OneTime}"
                        Padding="8,4"
                        AutomationProperties.Name="Media info entries">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="vm:MediaInfoEntry">
                                <Grid Padding="4,4" ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        Grid.Column="0"
                                        Text="{x:Bind Key}"
                                        FontWeight="SemiBold"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock
                                        Grid.Column="1"
                                        Text="{x:Bind Value}"
                                        TextWrapping="Wrap" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- Placeholder for other tabs -->
                    <TextBlock
                        Grid.Row="1"
                        Text="Select a file to view details."
                        Visibility="{x:Bind IsNotMediaInfoTab, Mode=OneTime}"
                        Style="{ThemeResource BodyTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center" />
                </Grid>
            </Border>
        </Grid>

        <!-- Bottom toolbar -->
        <Grid Grid.Row="1" Padding="12,6" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button
                Grid.Column="0"
                Command="{x:Bind ViewModel.ClearCommand}"
                AutomationProperties.Name="Clear files">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE74D;" FontSize="14" />
                    <TextBlock Text="Clear" />
                </StackPanel>
            </Button>

            <Button
                Grid.Column="1"
                Command="{x:Bind ViewModel.LoadFilesCommand}"
                AutomationProperties.Name="Load files">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE838;" FontSize="14" />
                    <TextBlock Text="Load" />
                </StackPanel>
            </Button>

            <TextBlock
                Grid.Column="2"
                Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                Style="{ThemeResource CaptionTextBlockStyle}"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                VerticalAlignment="Center"
                HorizontalAlignment="Right" />
        </Grid>
    </Grid>
</UserControl>
