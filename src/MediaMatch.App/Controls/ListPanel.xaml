<UserControl
    x:Class="MediaMatch.App.Controls.ListPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:MediaMatch.App.ViewModels"
    xmlns:local="using:MediaMatch.App.Controls"
    mc:Ignorable="d">

    <Grid RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Top toolbar: Pattern, From, To, Apply -->
        <Grid Grid.Row="0" Padding="12,8" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox
                Grid.Column="0"
                Header="Pattern"
                Text="{x:Bind ViewModel.Pattern, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                PlaceholderText="Sequence - {i.pad(2)}"
                AutomationProperties.Name="Pattern expression" />

            <NumberBox
                Grid.Column="1"
                Value="{x:Bind ViewModel.FromNumber, Mode=TwoWay}"
                Header="From"
                SpinButtonPlacementMode="Compact"
                Minimum="0"
                AutomationProperties.Name="From number"
                MinWidth="90" />

            <NumberBox
                Grid.Column="2"
                Value="{x:Bind ViewModel.ToNumber, Mode=TwoWay}"
                Header="To"
                SpinButtonPlacementMode="Compact"
                Minimum="0"
                AutomationProperties.Name="To number"
                MinWidth="90" />

            <Button
                Grid.Column="3"
                Command="{x:Bind ViewModel.ApplyPatternCommand}"
                AutomationProperties.Name="Generate sequence"
                Style="{ThemeResource AccentButtonStyle}"
                VerticalAlignment="Bottom">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE768;" FontSize="14" />
                    <TextBlock Text="Sequence" />
                </StackPanel>
            </Button>
        </Grid>

        <!-- File output list -->
        <Border Grid.Row="1"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Margin="12,0">
        <Grid>
            <ListView
                ItemsSource="{x:Bind ViewModel.Files}"
                Visibility="{x:Bind ViewModel.HasFiles, Mode=OneWay}"
                SelectionMode="None"
                Padding="0,0"
                AutomationProperties.Name="File output list">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="vm:ListFileItemViewModel">
                        <Grid Padding="4,6" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Grid.Column="0"
                                Text="{x:Bind FileName, Mode=OneWay}"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                TextTrimming="CharacterEllipsis" />
                            <TextBlock
                                Grid.Column="1"
                                Text="{x:Bind Output, Mode=OneWay}"
                                FontWeight="SemiBold"
                                TextTrimming="CharacterEllipsis" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Empty state -->
            <StackPanel
                x:Name="EmptyState"
                x:Load="{x:Bind local:ListPanel.Not(ViewModel.HasFiles), Mode=OneWay}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="8">
                <FontIcon Glyph="&#xE8A5;" FontSize="48" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="4">
                    <TextBlock
                        VerticalAlignment="Center"
                        Style="{ThemeResource BodyTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="Drop files here or" />
                    <HyperlinkButton
                        Padding="0"
                        VerticalAlignment="Center"
                        Command="{x:Bind ViewModel.LoadFilesCommand}"
                        Content="Load"
                        AutomationProperties.Name="Load files" />
                    <TextBlock
                        VerticalAlignment="Center"
                        Style="{ThemeResource BodyTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="to generate a list." />
                </StackPanel>
            </StackPanel>
        </Grid>
        </Border>

        <!-- Bottom toolbar -->
        <Grid Grid.Row="2" Padding="12,6" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button
                Grid.Column="0"
                Command="{x:Bind ViewModel.ClearCommand}"
                AutomationProperties.Name="Clear files">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE74D;" FontSize="14" />
                    <TextBlock Text="Clear" />
                </StackPanel>
            </Button>

            <DropDownButton
                Grid.Column="1"
                AutomationProperties.Name="Load files or folder">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE838;" FontSize="14" />
                    <TextBlock Text="Load" />
                </StackPanel>
                <DropDownButton.Flyout>
                    <MenuFlyout Placement="Top">
                        <MenuFlyoutItem Text="Files..." Command="{x:Bind ViewModel.LoadFilesCommand}"
                                        AutomationProperties.Name="Load individual files">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE8E5;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem Text="Folder..." Command="{x:Bind ViewModel.LoadFolderCommand}"
                                        AutomationProperties.Name="Load all files from a folder">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE8B7;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                    </MenuFlyout>
                </DropDownButton.Flyout>
            </DropDownButton>

            <Button
                Grid.Column="2"
                AutomationProperties.Name="Export list"
                IsEnabled="False"
                ToolTipService.ToolTip="Export (coming soon)">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xEDE1;" FontSize="14" />
                    <TextBlock Text="Export" />
                </StackPanel>
            </Button>

            <TextBlock
                Grid.Column="3"
                Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                Style="{ThemeResource CaptionTextBlockStyle}"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                VerticalAlignment="Center"
                HorizontalAlignment="Right" />
        </Grid>
    </Grid>
</UserControl>
