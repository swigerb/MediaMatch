<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog
    x:Class="MediaMatch.App.Dialogs.PresetEditorDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Edit Preset"
    CloseButtonText="Cancel"
    DefaultButton="Primary"
    PrimaryButtonText="Save"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel MinWidth="560" Spacing="16" Padding="0,0,16,0">

            <!-- Name -->
            <StackPanel Spacing="4">
                <TextBlock
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="Name" />
                <TextBox
                    Text="{x:Bind ViewModel.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    PlaceholderText="e.g., TV Shows → Plex"
                    AutomationProperties.Name="Preset name" />
            </StackPanel>

            <!-- Input Folder -->
            <StackPanel Spacing="4">
                <TextBlock
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="Input Folder" />
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox
                        Grid.Column="0"
                        Text="{x:Bind ViewModel.InputFolder, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="Source folder path"
                        AutomationProperties.Name="Input folder path" />
                    <Button
                        Grid.Column="1"
                        Content="Browse"
                        Click="BrowseInputFolder_Click"
                        AutomationProperties.Name="Browse input folder" />
                </Grid>
            </StackPanel>

            <!-- Include Filter -->
            <StackPanel Spacing="4">
                <TextBlock
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="Include Filter" />
                <TextBox
                    Text="{x:Bind ViewModel.IncludeFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    PlaceholderText="*.mkv, *.mp4"
                    AutomationProperties.Name="Include filter pattern" />
            </StackPanel>

            <!-- Expression / Rename Pattern -->
            <StackPanel Spacing="4">
                <TextBlock
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="Expression / Rename Pattern" />
                <TextBox
                    Text="{x:Bind ViewModel.RenamePattern, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    FontFamily="Cascadia Code, Consolas, Courier New"
                    PlaceholderText="{}{SeriesName}/Season {Season}/{SeriesName} - S{Season:D2}E{Episode:D2} - {Title}{extension}"
                    AutomationProperties.Name="Rename expression pattern" />
            </StackPanel>

            <!-- Options Expander -->
            <Expander
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Stretch"
                IsExpanded="False"
                AutomationProperties.Name="Advanced options">
                <Expander.Header>
                    <TextBlock Text="Options" />
                </Expander.Header>
                <Expander.Content>
                    <StackPanel Spacing="12">

                        <!-- Datasource -->
                        <StackPanel Spacing="4">
                            <TextBlock
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="Datasource" />
                            <ComboBox
                                HorizontalAlignment="Stretch"
                                ItemsSource="{x:Bind ViewModel.DatasourceOptions}"
                                SelectedIndex="{x:Bind ViewModel.SelectedDatasourceIndex, Mode=TwoWay}"
                                AutomationProperties.Name="Datasource" />
                        </StackPanel>

                        <!-- Language -->
                        <StackPanel Spacing="4">
                            <TextBlock
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="Language" />
                            <ComboBox
                                HorizontalAlignment="Stretch"
                                ItemsSource="{x:Bind ViewModel.LanguageOptions}"
                                SelectedIndex="{x:Bind ViewModel.SelectedLanguageIndex, Mode=TwoWay}"
                                AutomationProperties.Name="Language" />
                        </StackPanel>

                        <!-- Episode Order -->
                        <StackPanel Spacing="4">
                            <TextBlock
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="Episode Order" />
                            <ComboBox
                                HorizontalAlignment="Stretch"
                                ItemsSource="{x:Bind ViewModel.EpisodeOrderOptions}"
                                SelectedIndex="{x:Bind ViewModel.SelectedEpisodeOrderIndex, Mode=TwoWay}"
                                AutomationProperties.Name="Episode order" />
                        </StackPanel>

                        <!-- Match Mode -->
                        <StackPanel Spacing="4">
                            <TextBlock
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="Match Mode" />
                            <ComboBox
                                HorizontalAlignment="Stretch"
                                ItemsSource="{x:Bind ViewModel.MatchModeOptions}"
                                SelectedIndex="{x:Bind ViewModel.SelectedMatchModeIndex, Mode=TwoWay}"
                                AutomationProperties.Name="Match mode" />
                        </StackPanel>

                        <!-- Rename Action -->
                        <StackPanel Spacing="4">
                            <TextBlock
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="Rename Action" />
                            <ComboBox
                                HorizontalAlignment="Stretch"
                                ItemsSource="{x:Bind ViewModel.RenameActionOptions}"
                                SelectedIndex="{x:Bind ViewModel.SelectedRenameActionIndex, Mode=TwoWay}"
                                AutomationProperties.Name="Rename action" />
                        </StackPanel>

                    </StackPanel>
                </Expander.Content>
            </Expander>

            <!-- Keyboard Shortcut -->
            <StackPanel Spacing="4">
                <TextBlock
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="Keyboard Shortcut" />
                <ComboBox
                    ItemsSource="{x:Bind ViewModel.KeyboardShortcutOptions}"
                    SelectedIndex="{x:Bind ViewModel.SelectedShortcutIndex, Mode=TwoWay}"
                    AutomationProperties.Name="Keyboard shortcut"
                    MinWidth="200" />
            </StackPanel>

            <!-- Output Folder -->
            <StackPanel Spacing="4">
                <TextBlock
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="Output Folder" />
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox
                        Grid.Column="0"
                        Text="{x:Bind ViewModel.OutputFolder, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="Target output folder path"
                        AutomationProperties.Name="Output folder path" />
                    <Button
                        Grid.Column="1"
                        Content="Browse"
                        Click="BrowseOutputFolder_Click"
                        AutomationProperties.Name="Browse output folder" />
                </Grid>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</ContentDialog>
