<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog
    x:Class="MediaMatch.App.Dialogs.MediaInfoInspectorDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:MediaMatch.App.ViewModels"
    Title="MediaInfo Inspector"
    CloseButtonText="Close"
    DefaultButton="Close"
    mc:Ignorable="d">

    <Grid MinWidth="640" MinHeight="420">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- File path display + Open File button -->
        <Grid Grid.Row="0" ColumnSpacing="8" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock
                Grid.Column="0"
                VerticalAlignment="Center"
                Text="{x:Bind ViewModel.FilePath, Mode=OneWay}"
                TextTrimming="CharacterEllipsis"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Style="{StaticResource CaptionTextBlockStyle}"
                IsTextSelectionEnabled="True"
                AutomationProperties.Name="File path" />
            <Button
                Grid.Column="1"
                Content="Open File…"
                Click="OpenFile_Click"
                AutomationProperties.Name="Open a different file" />
        </Grid>

        <!-- Loading indicator -->
        <StackPanel
            Grid.Row="1"
            Orientation="Horizontal"
            Spacing="8"
            Visibility="{x:Bind BoolToVisibility(ViewModel.IsLoading), Mode=OneWay}"
            Margin="0,0,0,8">
            <ProgressRing Width="20" Height="20" IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />
            <TextBlock
                VerticalAlignment="Center"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="Analyzing file…" />
        </StackPanel>

        <!-- Error / ffprobe unavailable message -->
        <InfoBar
            Grid.Row="1"
            IsOpen="{x:Bind HasError(ViewModel.ErrorMessage), Mode=OneWay}"
            IsClosable="False"
            Severity="Warning"
            Title="Cannot inspect file"
            Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
            Visibility="{x:Bind ErrorVisibility(ViewModel.ErrorMessage), Mode=OneWay}"
            Margin="0,0,0,8" />

        <!-- Tabbed stream content -->
        <Pivot
            Grid.Row="2"
            Visibility="{x:Bind BoolToVisibility(ViewModel.HasResult), Mode=OneWay}">

            <!-- General tab -->
            <PivotItem Header="General">
                <ListView
                    ItemsSource="{x:Bind ViewModel.GeneralProperties, Mode=OneWay}"
                    SelectionMode="None"
                    AutomationProperties.Name="General properties">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="vm:PropertyItem">
                            <Grid Padding="4,4" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="200" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Grid.Column="0"
                                    Text="{x:Bind Key}"
                                    FontWeight="SemiBold"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    TextTrimming="CharacterEllipsis" />
                                <TextBlock
                                    Grid.Column="1"
                                    Text="{x:Bind Value}"
                                    IsTextSelectionEnabled="True"
                                    TextWrapping="Wrap" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </PivotItem>

            <!-- Video tab -->
            <PivotItem Header="Video">
                <ListView
                    ItemsSource="{x:Bind ViewModel.VideoStreams, Mode=OneWay}"
                    SelectionMode="None"
                    AutomationProperties.Name="Video streams">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="vm:StreamGroup">
                            <StackPanel Spacing="4" Margin="0,0,0,12">
                                <TextBlock
                                    Text="{x:Bind Name}"
                                    Style="{StaticResource BodyStrongTextBlockStyle}"
                                    Margin="0,4,0,4" />
                                <ItemsRepeater ItemsSource="{x:Bind Properties}">
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate x:DataType="vm:PropertyItem">
                                            <Grid Padding="4,2" ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="200" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock
                                                    Grid.Column="0"
                                                    Text="{x:Bind Key}"
                                                    FontWeight="SemiBold"
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    TextTrimming="CharacterEllipsis" />
                                                <TextBlock
                                                    Grid.Column="1"
                                                    Text="{x:Bind Value}"
                                                    IsTextSelectionEnabled="True"
                                                    TextWrapping="Wrap" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </PivotItem>

            <!-- Audio tab -->
            <PivotItem Header="Audio">
                <ListView
                    ItemsSource="{x:Bind ViewModel.AudioStreams, Mode=OneWay}"
                    SelectionMode="None"
                    AutomationProperties.Name="Audio streams">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="vm:StreamGroup">
                            <StackPanel Spacing="4" Margin="0,0,0,12">
                                <TextBlock
                                    Text="{x:Bind Name}"
                                    Style="{StaticResource BodyStrongTextBlockStyle}"
                                    Margin="0,4,0,4" />
                                <ItemsRepeater ItemsSource="{x:Bind Properties}">
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate x:DataType="vm:PropertyItem">
                                            <Grid Padding="4,2" ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="200" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock
                                                    Grid.Column="0"
                                                    Text="{x:Bind Key}"
                                                    FontWeight="SemiBold"
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    TextTrimming="CharacterEllipsis" />
                                                <TextBlock
                                                    Grid.Column="1"
                                                    Text="{x:Bind Value}"
                                                    IsTextSelectionEnabled="True"
                                                    TextWrapping="Wrap" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </PivotItem>

            <!-- Subtitles tab -->
            <PivotItem Header="Subtitles">
                <ListView
                    ItemsSource="{x:Bind ViewModel.TextStreams, Mode=OneWay}"
                    SelectionMode="None"
                    AutomationProperties.Name="Subtitle streams">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="vm:StreamGroup">
                            <StackPanel Spacing="4" Margin="0,0,0,12">
                                <TextBlock
                                    Text="{x:Bind Name}"
                                    Style="{StaticResource BodyStrongTextBlockStyle}"
                                    Margin="0,4,0,4" />
                                <ItemsRepeater ItemsSource="{x:Bind Properties}">
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate x:DataType="vm:PropertyItem">
                                            <Grid Padding="4,2" ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="200" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock
                                                    Grid.Column="0"
                                                    Text="{x:Bind Key}"
                                                    FontWeight="SemiBold"
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    TextTrimming="CharacterEllipsis" />
                                                <TextBlock
                                                    Grid.Column="1"
                                                    Text="{x:Bind Value}"
                                                    IsTextSelectionEnabled="True"
                                                    TextWrapping="Wrap" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </PivotItem>
        </Pivot>

        <!-- Bottom toolbar: Copy to Clipboard -->
        <StackPanel
            Grid.Row="3"
            Orientation="Horizontal"
            HorizontalAlignment="Left"
            Spacing="8"
            Margin="0,12,0,0"
            Visibility="{x:Bind BoolToVisibility(ViewModel.HasResult), Mode=OneWay}">
            <Button
                Content="📋 Copy to Clipboard"
                Click="CopyToClipboard_Click"
                AutomationProperties.Name="Copy media info to clipboard" />
        </StackPanel>
    </Grid>
</ContentDialog>
