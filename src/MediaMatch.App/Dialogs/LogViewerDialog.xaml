<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog
    x:Class="MediaMatch.App.Dialogs.LogViewerDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Logs &amp; Diagnostics"
    PrimaryButtonText="Close"
    DefaultButton="Primary"
    FullSizeDesired="True">

    <Grid Width="900" MinHeight="500" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Tab selector -->
        <SelectorBar x:Name="TabSelector" Grid.Row="0" SelectionChanged="TabSelector_SelectionChanged">
            <SelectorBarItem Text="Logs" IsSelected="True" Tag="logs"
                             AutomationProperties.Name="Logs tab" />
            <SelectorBarItem Text="Traces" Tag="traces"
                             AutomationProperties.Name="Traces tab" />
        </SelectorBar>

        <!-- Toolbar: Search + Filter + Actions -->
        <Grid Grid.Row="1" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox
                x:Name="SearchBox"
                Grid.Column="0"
                PlaceholderText="Search logs..."
                TextChanged="SearchBox_TextChanged"
                AutomationProperties.Name="Search logs" />

            <ComboBox
                x:Name="LevelFilter"
                Grid.Column="1"
                Width="140"
                SelectedIndex="0"
                SelectionChanged="LevelFilter_SelectionChanged"
                AutomationProperties.Name="Log level filter">
                <ComboBoxItem Content="All Levels" />
                <ComboBoxItem Content="Verbose" />
                <ComboBoxItem Content="Debug" />
                <ComboBoxItem Content="Information" />
                <ComboBoxItem Content="Warning" />
                <ComboBoxItem Content="Error" />
                <ComboBoxItem Content="Fatal" />
            </ComboBox>

            <Button
                Grid.Column="2"
                ToolTipService.ToolTip="Clear all logs"
                Click="ClearLogs_Click"
                AutomationProperties.Name="Clear logs">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE74D;" FontSize="14" />
                    <TextBlock Text="Clear" />
                </StackPanel>
            </Button>

            <Button
                Grid.Column="3"
                ToolTipService.ToolTip="Refresh"
                Click="RefreshLogs_Click"
                AutomationProperties.Name="Refresh logs">
                <FontIcon Glyph="&#xE72C;" FontSize="14" />
            </Button>

            <Button
                Grid.Column="4"
                ToolTipService.ToolTip="Open logs folder"
                Click="OpenLogsFolder_Click"
                AutomationProperties.Name="Open logs folder">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xED25;" FontSize="14" />
                    <TextBlock Text="Open Folder" />
                </StackPanel>
            </Button>
        </Grid>

        <!-- Logs list -->
        <Border
            x:Name="LogsPanel"
            Grid.Row="2"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="4"
            Background="{ThemeResource LayerFillColorDefaultBrush}">
            <ListView
                x:Name="LogListView"
                SelectionMode="None"
                AutomationProperties.Name="Log entries">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="8,6" ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="50" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Grid.Column="0"
                                Text="{Binding Timestamp}"
                                FontFamily="Cascadia Mono,Consolas"
                                FontSize="11"
                                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                VerticalAlignment="Top" />
                            <Border
                                Grid.Column="1"
                                CornerRadius="3"
                                Padding="4,1"
                                Background="{Binding LevelBrush}"
                                VerticalAlignment="Top"
                                HorizontalAlignment="Center">
                                <TextBlock
                                    Text="{Binding Level}"
                                    FontSize="10"
                                    FontWeight="SemiBold"
                                    Foreground="White"
                                    HorizontalAlignment="Center" />
                            </Border>
                            <TextBlock
                                Grid.Column="2"
                                Text="{Binding Message}"
                                FontFamily="Cascadia Mono,Consolas"
                                FontSize="12"
                                TextWrapping="Wrap"
                                Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                VerticalAlignment="Top" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>

        <!-- Traces panel (hidden by default) -->
        <Border
            x:Name="TracesPanel"
            Grid.Row="2"
            Visibility="Collapsed"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="4"
            Background="{ThemeResource LayerFillColorDefaultBrush}">
            <ListView
                x:Name="TraceListView"
                SelectionMode="None"
                AutomationProperties.Name="Trace entries">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="8,6" ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="60" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Grid.Column="0"
                                Text="{Binding Timestamp}"
                                FontFamily="Cascadia Mono,Consolas"
                                FontSize="11"
                                Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                            <TextBlock
                                Grid.Column="1"
                                Text="{Binding OperationName}"
                                FontFamily="Cascadia Mono,Consolas"
                                FontSize="11"
                                Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                TextTrimming="CharacterEllipsis" />
                            <TextBlock
                                Grid.Column="2"
                                Text="{Binding Duration}"
                                FontFamily="Cascadia Mono,Consolas"
                                FontSize="11"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock
                                Grid.Column="3"
                                Text="{Binding Tags}"
                                FontFamily="Cascadia Mono,Consolas"
                                FontSize="11"
                                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                TextTrimming="CharacterEllipsis" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>

        <!-- Footer summary -->
        <Grid Grid.Row="3">
            <TextBlock
                x:Name="LogCountText"
                FontSize="12"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                VerticalAlignment="Center" />
        </Grid>
    </Grid>
</ContentDialog>
