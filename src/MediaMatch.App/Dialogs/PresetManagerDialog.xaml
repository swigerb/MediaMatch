<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog
    x:Class="MediaMatch.App.Dialogs.PresetManagerDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:config="using:MediaMatch.Core.Configuration"
    Title="Manage Presets"
    CloseButtonText="Cancel"
    DefaultButton="Primary"
    PrimaryButtonText="Save"
    mc:Ignorable="d">

    <StackPanel MinWidth="480" Spacing="12">
        <ListView
            x:Name="PresetList"
            MaxHeight="320"
            SelectionMode="Single"
            AutomationProperties.Name="Preset list">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="config:PresetDefinitionSettings">
                    <Grid Padding="4,8" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            Text="{x:Bind Name, Mode=OneWay}" />
                        <Button
                            Grid.Column="1"
                            Content="&#xE70F;"
                            FontFamily="{ThemeResource SymbolThemeFontFamily}"
                            ToolTipService.ToolTip="Edit"
                            Click="EditPreset_Click"
                            AutomationProperties.Name="Edit preset" />
                        <Button
                            Grid.Column="2"
                            Content="&#xE74D;"
                            FontFamily="{ThemeResource SymbolThemeFontFamily}"
                            ToolTipService.ToolTip="Delete"
                            Click="DeletePreset_Click"
                            AutomationProperties.Name="Delete preset" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <TextBlock
            x:Name="EmptyMessage"
            HorizontalAlignment="Center"
            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
            Text="No presets yet. Click Add to create one."
            AutomationProperties.Name="No presets" />

        <Button
            HorizontalAlignment="Left"
            Click="AddPreset_Click"
            AutomationProperties.Name="Add new preset">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <FontIcon Glyph="&#xE710;" FontSize="14" />
                <TextBlock Text="Add Preset" />
            </StackPanel>
        </Button>
    </StackPanel>
</ContentDialog>
