<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog
    x:Class="MediaMatch.App.Dialogs.ExpressionEditorDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:MediaMatch.App.ViewModels"
    Title="Expression Editor"
    CloseButtonText="Cancel"
    DefaultButton="Primary"
    PrimaryButtonText="Apply"
    mc:Ignorable="d">

    <StackPanel MinWidth="560" Spacing="16">

        <!-- Example expressions -->
        <StackPanel Spacing="4">
            <TextBlock
                Style="{StaticResource CaptionTextBlockStyle}"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="Templates" />
            <ComboBox
                x:Name="ExamplesComboBox"
                HorizontalAlignment="Stretch"
                DisplayMemberPath="Name"
                ItemsSource="{x:Bind ViewModel.ExampleExpressions}"
                SelectedItem="{x:Bind ViewModel.SelectedExample, Mode=TwoWay}"
                AutomationProperties.Name="Expression templates" />
        </StackPanel>

        <!-- Expression input -->
        <StackPanel Spacing="4">
            <TextBlock
                Style="{StaticResource CaptionTextBlockStyle}"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="Expression" />
            <TextBox
                x:Name="ExpressionTextBox"
                MinHeight="80"
                AcceptsReturn="True"
                FontFamily="Cascadia Code, Consolas, Courier New"
                Text="{x:Bind ViewModel.Expression, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                TextWrapping="Wrap"
                SelectionChanged="ExpressionTextBox_SelectionChanged"
                AutomationProperties.Name="Expression input" />
        </StackPanel>

        <!-- Validation indicator -->
        <StackPanel Orientation="Horizontal" Spacing="8">
            <FontIcon
                FontSize="14"
                Glyph="{x:Bind ValidationGlyph(ViewModel.IsValid), Mode=OneWay}"
                Foreground="{x:Bind ValidationBrush(ViewModel.IsValid), Mode=OneWay}" />
            <TextBlock
                Style="{StaticResource CaptionTextBlockStyle}"
                Foreground="{x:Bind ValidationBrush(ViewModel.IsValid), Mode=OneWay}"
                Text="{x:Bind ViewModel.ValidationMessage, Mode=OneWay}" />
        </StackPanel>

        <!-- Live preview -->
        <StackPanel Spacing="4">
            <TextBlock
                Style="{StaticResource CaptionTextBlockStyle}"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="Preview" />
            <Border
                Padding="12,8"
                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                CornerRadius="4">
                <TextBlock
                    FontFamily="Cascadia Code, Consolas, Courier New"
                    IsTextSelectionEnabled="True"
                    Text="{x:Bind ViewModel.Preview, Mode=OneWay}"
                    TextWrapping="Wrap"
                    Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
            </Border>
        </StackPanel>

        <!-- Available tokens -->
        <Expander
            HorizontalAlignment="Stretch"
            HorizontalContentAlignment="Stretch"
            AutomationProperties.Name="Available tokens">
            <Expander.Header>
                <TextBlock Text="Available Tokens" />
            </Expander.Header>
            <Expander.Content>
                <ItemsRepeater ItemsSource="{x:Bind ViewModel.AvailableTokens}">
                    <ItemsRepeater.Layout>
                        <UniformGridLayout
                            MinColumnSpacing="4"
                            MinRowSpacing="4"
                            MinItemWidth="160"
                            ItemsStretch="Fill" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="vm:TokenInfo">
                            <Button
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Padding="8,6"
                                Click="TokenButton_Click"
                                Tag="{x:Bind Name}"
                                AutomationProperties.Name="{x:Bind Name}"
                                ToolTipService.ToolTip="{x:Bind Description}">
                                <StackPanel Spacing="2">
                                    <TextBlock
                                        FontFamily="Cascadia Code, Consolas, Courier New"
                                        FontSize="12"
                                        Text="{x:Bind Name}" />
                                    <TextBlock
                                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                        Style="{StaticResource CaptionTextBlockStyle}"
                                        Text="{x:Bind Description}"
                                        TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </Expander.Content>
        </Expander>

    </StackPanel>
</ContentDialog>
