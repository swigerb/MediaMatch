<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="MediaMatch.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:MediaMatch.App"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Media Match"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
            <RowDefinition Height="28" />
        </Grid.RowDefinitions>

        <TitleBar
            x:Name="AppTitleBar"
            Title="Media Match"
            BackRequested="TitleBar_BackRequested"
            IsBackButtonVisible="{x:Bind NavFrame.CanGoBack, Mode=OneWay}"
            IsPaneToggleButtonVisible="True"
            PaneToggleRequested="TitleBar_PaneToggleRequested">
            <TitleBar.IconSource>
                <FontIconSource Glyph="&#xE8AB;" />
            </TitleBar.IconSource>
        </TitleBar>

        <NavigationView
            x:Name="NavView"
            Grid.Row="1"
            IsBackButtonVisible="Collapsed"
            IsPaneToggleButtonVisible="False"
            IsSettingsVisible="True"
            SelectionChanged="NavView_SelectionChanged"
            AutomationProperties.Name="Main navigation">
            <NavigationView.MenuItems>
                <NavigationViewItem
                    Content="Home"
                    IsSelected="True"
                    Tag="home"
                    AutomationProperties.Name="Home page"
                    AccessKey="H">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE80F;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="History" Tag="history"
                    AutomationProperties.Name="History page"
                    AccessKey="I">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE81C;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="About" Tag="about"
                    AutomationProperties.Name="About page"
                    AccessKey="B">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xEA3A;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>
            <Frame x:Name="NavFrame" AutomationProperties.Name="Page content" />
        </NavigationView>

        <!-- Status Bar -->
        <Grid Grid.Row="2"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
              BorderThickness="0,1,0,0"
              Padding="8,0">
            <TextBlock
                x:Name="VersionText"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="12"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Padding="4" />
        </Grid>

        <!-- Splash Screen Overlay -->
        <Grid x:Name="SplashOverlay"
              Grid.RowSpan="3"
              Canvas.ZIndex="100"
              Background="{ThemeResource SolidBackgroundFillColorBaseBrush}">
            <Grid.Resources>
                <Storyboard x:Name="SplashFadeOut">
                    <DoubleAnimation
                        Storyboard.TargetName="SplashOverlay"
                        Storyboard.TargetProperty="Opacity"
                        From="1.0"
                        To="0.0"
                        Duration="0:0:0.4">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut" />
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </Grid.Resources>

            <!-- Centered card — roughly 1/3 of the window -->
            <Border
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                MinWidth="340"
                MaxWidth="420"
                MinHeight="320"
                Padding="40,36"
                CornerRadius="8"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <Border.Shadow>
                    <ThemeShadow />
                </Border.Shadow>
                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="16">

                    <!-- Large logo -->
                    <Image
                        Source="Assets/MediaMatch_Logo.png"
                        Width="180"
                        Height="180"
                        HorizontalAlignment="Center"
                        Stretch="Uniform" />

                    <!-- App name -->
                    <TextBlock
                        Text="Media Match"
                        FontSize="24"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                        HorizontalAlignment="Center" />

                    <!-- Version -->
                    <TextBlock
                        x:Name="SplashVersionText"
                        FontSize="13"
                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                        HorizontalAlignment="Center" />

                    <!-- Loading indicator -->
                    <ProgressBar
                        IsIndeterminate="True"
                        Width="200"
                        HorizontalAlignment="Center"
                        Margin="0,8,0,0" />

                    <TextBlock
                        Text="Loading…"
                        FontSize="12"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        HorizontalAlignment="Center" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
