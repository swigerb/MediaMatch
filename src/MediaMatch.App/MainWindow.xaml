<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="MediaMatch.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:MediaMatch.App"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="MediaMatch"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
            <RowDefinition Height="28" />
        </Grid.RowDefinitions>

        <TitleBar
            x:Name="AppTitleBar"
            Title="MediaMatch"
            BackRequested="TitleBar_BackRequested"
            IsBackButtonVisible="{x:Bind NavFrame.CanGoBack, Mode=OneWay}"
            IsPaneToggleButtonVisible="True"
            PaneToggleRequested="TitleBar_PaneToggleRequested">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="Assets/AppIcon.ico" />
            </TitleBar.IconSource>
        </TitleBar>

        <NavigationView
            x:Name="NavView"
            Grid.Row="1"
            IsBackButtonVisible="Collapsed"
            IsPaneToggleButtonVisible="False"
            IsSettingsVisible="True"
            SelectionChanged="NavView_SelectionChanged"
            AutomationProperties.Name="Main navigation">
            <NavigationView.MenuItems>
                <NavigationViewItem
                    Content="Home"
                    IsSelected="True"
                    Tag="home"
                    AutomationProperties.Name="Home page"
                    AccessKey="H">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE80F;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="History" Tag="history"
                    AutomationProperties.Name="History page"
                    AccessKey="I">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE81C;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="About" Tag="about"
                    AutomationProperties.Name="About page"
                    AccessKey="B">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xEA3A;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>
            <Frame x:Name="NavFrame" AutomationProperties.Name="Page content" />
        </NavigationView>

        <!-- Status Bar -->
        <Grid Grid.Row="2"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
              BorderThickness="0,1,0,0"
              Padding="8,0">
            <TextBlock
                x:Name="VersionText"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="12"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Padding="4" />
        </Grid>

        <!-- Splash Screen Overlay -->
        <Grid x:Name="SplashOverlay"
              Grid.RowSpan="3"
              Canvas.ZIndex="100"
              Background="#1A1A2E">
            <Grid.Resources>
                <Storyboard x:Name="SplashFadeOut">
                    <DoubleAnimation
                        Storyboard.TargetName="SplashOverlay"
                        Storyboard.TargetProperty="Opacity"
                        From="1.0"
                        To="0.0"
                        Duration="0:0:0.5" />
                </Storyboard>
            </Grid.Resources>
            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="16">
                <Image
                    Source="Assets/MediaMatch_Logo.png"
                    Width="180"
                    Height="180"
                    HorizontalAlignment="Center" />
                <TextBlock
                    Text="MediaMatch"
                    FontSize="28"
                    FontWeight="SemiBold"
                    Foreground="White"
                    HorizontalAlignment="Center" />
                <ProgressRing
                    IsActive="True"
                    Width="32"
                    Height="32"
                    HorizontalAlignment="Center"
                    Foreground="White" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
