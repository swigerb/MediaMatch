<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="MediaMatch.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:MediaMatch.App"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Media Match"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
            <RowDefinition Height="28" />
        </Grid.RowDefinitions>

        <TitleBar
            x:Name="AppTitleBar"
            Title="Media Match"
            BackRequested="TitleBar_BackRequested"
            IsBackButtonVisible="{x:Bind NavFrame.CanGoBack, Mode=OneWay}"
            IsPaneToggleButtonVisible="True"
            PaneToggleRequested="TitleBar_PaneToggleRequested">
            <TitleBar.IconSource>
                <FontIconSource Glyph="&#xE8AB;" />
            </TitleBar.IconSource>
        </TitleBar>

        <NavigationView
            x:Name="NavView"
            Grid.Row="1"
            IsBackButtonVisible="Collapsed"
            IsPaneToggleButtonVisible="False"
            IsSettingsVisible="True"
            SelectionChanged="NavView_SelectionChanged"
            AutomationProperties.Name="Main navigation">
            <NavigationView.MenuItems>
                <NavigationViewItem
                    Content="Home"
                    IsSelected="True"
                    Tag="home"
                    AutomationProperties.Name="Home page"
                    AccessKey="H">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE80F;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="History" Tag="history"
                    AutomationProperties.Name="History page"
                    AccessKey="I">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE81C;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="About" Tag="about"
                    AutomationProperties.Name="About page"
                    AccessKey="B">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xEA3A;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>
            <Frame x:Name="NavFrame" AutomationProperties.Name="Page content" />
        </NavigationView>

        <!-- Status Bar -->
        <Grid Grid.Row="2"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
              BorderThickness="0,1,0,0"
              Padding="8,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock
                x:Name="VersionText"
                Grid.Column="0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="12"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Padding="4" />
            <Button
                Grid.Column="2"
                Click="LogViewer_Click"
                ToolTipService.ToolTip="Logs &amp; Diagnostics"
                Background="Transparent"
                BorderThickness="0"
                Padding="6,2"
                VerticalAlignment="Center"
                AutomationProperties.Name="Open log viewer">
                <FontIcon Glyph="&#xEA37;" FontSize="14"
                          Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </Button>
        </Grid>

        <!-- Splash Screen Overlay -->
        <Grid x:Name="SplashOverlay"
              Grid.RowSpan="3"
              Canvas.ZIndex="100"
              Background="{ThemeResource SolidBackgroundFillColorBaseBrush}">
            <Grid.Resources>
                <Storyboard x:Name="SplashFadeOut">
                    <DoubleAnimation
                        Storyboard.TargetName="SplashOverlay"
                        Storyboard.TargetProperty="Opacity"
                        From="1.0"
                        To="0.0"
                        Duration="0:0:0.4">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut" />
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </Grid.Resources>

            <!-- Centered card — roughly 1/3 of the window -->
            <!-- Outer glow border for 3D depth effect -->
            <Border
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                MinWidth="480"
                MaxWidth="560"
                MinHeight="400"
                CornerRadius="12"
                BorderBrush="{ThemeResource ControlStrokeColorSecondaryBrush}"
                BorderThickness="1"
                Padding="2">
                <!-- Inner card with elevated surface -->
                <Border
                    CornerRadius="10"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    Padding="48,40">
                    <Border.Shadow>
                        <ThemeShadow />
                    </Border.Shadow>
                    <StackPanel
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="20">

                        <!-- Large logo — source is 5632×3072 (wide), give it room -->
                        <Image
                            Source="Assets/MediaMatch_Logo.png"
                            MaxWidth="400"
                            MaxHeight="220"
                            HorizontalAlignment="Center"
                            Stretch="Uniform" />

                        <!-- App name -->
                        <TextBlock
                            Text="Media Match"
                            FontSize="28"
                            FontWeight="SemiBold"
                            Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                            HorizontalAlignment="Center" />

                        <!-- Version -->
                        <TextBlock
                            x:Name="SplashVersionText"
                            FontSize="13"
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                            HorizontalAlignment="Center"
                            Margin="0,-8,0,0" />

                        <!-- Loading indicator -->
                        <StackPanel Spacing="8" HorizontalAlignment="Center">
                            <ProgressBar
                                IsIndeterminate="True"
                                Width="260"
                                HorizontalAlignment="Center" />
                            <TextBlock
                                Text="Loading…"
                                FontSize="12"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                HorizontalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Border>
        </Grid>
    </Grid>
</Window>
