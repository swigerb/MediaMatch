<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="MediaMatch.App.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:MediaMatch.App.Pages"
    xmlns:vm="using:MediaMatch.App.ViewModels"
    xmlns:converters="using:MediaMatch.App.Converters"
    xmlns:controls="using:MediaMatch.App.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    AllowDrop="True"
    DragOver="Page_DragOver"
    Drop="Page_Drop"
    AutomationProperties.Name="File Matching">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <converters:MatchModeBrushConverter x:Key="MatchModeBrush" />

        <!-- Extension badge style -->
        <Style x:Key="ExtensionBadgeStyle" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource SystemFillColorCautionBackgroundBrush}" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Right" />
        </Style>
    </Page.Resources>

    <Page.KeyboardAccelerators>
        <KeyboardAccelerator Key="O" Modifiers="Control" />
        <KeyboardAccelerator Key="A" Modifiers="Control" />
        <KeyboardAccelerator Key="Delete" />
        <KeyboardAccelerator Key="Z" Modifiers="Control" />
        <KeyboardAccelerator Key="F5" />
        <KeyboardAccelerator Key="F1" />
    </Page.KeyboardAccelerators>

    <Grid Padding="16,12,16,12" RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Notification InfoBar -->
        <InfoBar
            x:Name="NotificationBar"
            Grid.Row="0"
            IsClosable="True"
            IsOpen="False"
            AutomationProperties.LiveSetting="Assertive"
            AutomationProperties.Name="Notification" />

        <!-- Mode SelectorBar + Presets -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <SelectorBar
                x:Name="ModeSelectorBar"
                Grid.Column="0"
                SelectionChanged="ModeSelectorBar_SelectionChanged"
                AutomationProperties.Name="Mode selector">
                <SelectorBarItem x:Name="RenameMode" Text="Rename" IsSelected="True"
                                 AutomationProperties.Name="Rename mode" />
                <SelectorBarItem x:Name="EpisodesMode" Text="Episodes"
                                 AutomationProperties.Name="Episodes mode" />
                <SelectorBarItem x:Name="SubtitlesMode" Text="Subtitles"
                                 AutomationProperties.Name="Subtitles mode" />
                <SelectorBarItem x:Name="SfvMode" Text="SFV"
                                 AutomationProperties.Name="SFV verification mode" />
                <SelectorBarItem x:Name="FilterMode" Text="Filter"
                                 AutomationProperties.Name="Filter mode" />
                <SelectorBarItem x:Name="ListMode" Text="List"
                                 AutomationProperties.Name="List mode" />
            </SelectorBar>

            <StackPanel
                Grid.Column="1"
                Orientation="Horizontal"
                Spacing="4"
                VerticalAlignment="Center">
                <DropDownButton
                    x:Name="PresetsDropDown"
                    AutomationProperties.Name="Presets"
                    ToolTipService.ToolTip="Apply a saved preset">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE762;" FontSize="14" />
                        <TextBlock Text="{x:Bind ViewModel.PresetsButtonText, Mode=OneWay}" />
                    </StackPanel>
                    <DropDownButton.Flyout>
                        <MenuFlyout x:Name="PresetsFlyout" />
                    </DropDownButton.Flyout>
                </DropDownButton>
            </StackPanel>
        </Grid>

        <!-- Batch Progress Bar -->
        <StackPanel
            Grid.Row="2"
            Spacing="4"
            Visibility="{x:Bind ViewModel.BatchProgress.IsRunning, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
            AutomationProperties.Name="Batch progress"
            AutomationProperties.LiveSetting="Polite">
            <ProgressBar
                Maximum="100"
                Value="{x:Bind ViewModel.BatchProgress.ProgressPercent, Mode=OneWay}" />
            <Grid>
                <TextBlock
                    HorizontalAlignment="Left"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="{x:Bind ViewModel.BatchProgress.ProgressText, Mode=OneWay}" />
                <TextBlock
                    HorizontalAlignment="Right"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                    Text="{x:Bind ViewModel.BatchProgress.CurrentFile, Mode=OneWay}"
                    TextTrimming="CharacterEllipsis" />
            </Grid>
        </StackPanel>

        <!-- Match Mode Indicator Banner -->
        <Border
            Grid.Row="3"
            Padding="12,8"
            CornerRadius="4"
            Background="{x:Bind ViewModel.ActiveMatchMode, Mode=OneWay, Converter={StaticResource MatchModeBrush}}"
            Opacity="0.15"
            Visibility="{x:Bind ViewModel.HasActiveMatchMode, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
        <Grid
            Grid.Row="3"
            Padding="12,8"
            Visibility="{x:Bind ViewModel.HasActiveMatchMode, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
            AutomationProperties.Name="Active match mode indicator">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <FontIcon
                    Glyph="{x:Bind ViewModel.ActiveMatchModeGlyph, Mode=OneWay}"
                    FontSize="16"
                    Foreground="{x:Bind ViewModel.ActiveMatchMode, Mode=OneWay, Converter={StaticResource MatchModeBrush}}" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontWeight="SemiBold"
                    Foreground="{x:Bind ViewModel.ActiveMatchMode, Mode=OneWay, Converter={StaticResource MatchModeBrush}}"
                    Text="{x:Bind ViewModel.ActiveMatchModeDisplay, Mode=OneWay}" />
            </StackPanel>
        </Grid>

        <!-- Main Content Area (Rename Mode = Dual Pane) -->
        <Grid Grid.Row="4" x:Name="RenamePanel">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- LEFT PANE: Source Files -->
            <Grid Grid.Column="0" RowSpacing="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Header -->
                <TextBlock
                    Grid.Row="0"
                    Text="Source Files"
                    Style="{StaticResource BodyStrongTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Padding="8,4" />

                <!-- File list or empty state — entire area is a drop target -->
                <Border x:Name="SourceFilesBorder"
                        Grid.Row="1"
                        BorderBrush="{x:Bind ViewModel.ActiveMatchMode, Mode=OneWay, Converter={StaticResource MatchModeBrush}}"
                        BorderThickness="1"
                        CornerRadius="4"
                        AllowDrop="True"
                        DragOver="SourceFiles_DragOver"
                        DragLeave="SourceFiles_DragLeave"
                        Drop="SourceFiles_Drop"
                        AutomationProperties.Name="Source files drop area. Drop files or folders here, or click to load.">
                    <Grid>
                    <!-- Empty state — clickable to show load flyout -->
                    <Grid
                        x:Name="EmptyStateArea"
                        Background="Transparent"
                        Tapped="EmptyState_Tapped"
                        Visibility="{x:Bind ViewModel.ShowEmptyState, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                        AutomationProperties.Name="Click to load files or folders">
                        <Grid.Resources>
                            <MenuFlyout x:Name="EmptyStateLoadFlyout" Placement="Bottom">
                                <MenuFlyoutItem Text="Load Files…" Command="{x:Bind ViewModel.AddFilesCommand}"
                                                AutomationProperties.Name="Load individual files">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE8E5;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem Text="Load Folder…" Command="{x:Bind ViewModel.AddFolderCommand}"
                                                AutomationProperties.Name="Load folder">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE8B7;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyout>
                        </Grid.Resources>
                        <StackPanel
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="12">
                            <FontIcon
                                HorizontalAlignment="Center"
                                FontSize="36"
                                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                Glyph="&#xE8B7;" />
                            <TextBlock
                                HorizontalAlignment="Center"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="Drop files here or click to load" />
                        </StackPanel>
                    </Grid>

                    <!-- Scanning -->
                    <StackPanel
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="8"
                        Visibility="{x:Bind ViewModel.IsScanning, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                        <ProgressRing Width="36" Height="36" IsActive="{x:Bind ViewModel.IsScanning, Mode=OneWay}" />
                        <TextBlock
                            HorizontalAlignment="Center"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="Scanning…" />
                    </StackPanel>

                    <!-- Original files list -->
                    <ListView
                        ItemsSource="{x:Bind ViewModel.OriginalFiles, Mode=OneWay}"
                        SelectionMode="Extended"
                        Visibility="{x:Bind ViewModel.HasFiles, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                        AutomationProperties.Name="Original files list">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="vm:FileItemViewModel">
                                <Grid Padding="8,4" ColumnSpacing="8"
                                      AutomationProperties.Name="{x:Bind AutomationName, Mode=OneWay}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        Grid.Column="0"
                                        VerticalAlignment="Center"
                                        Text="{x:Bind OriginalFileName, Mode=OneWay}"
                                        TextTrimming="CharacterEllipsis" />
                                    <Border Grid.Column="1" Style="{StaticResource ExtensionBadgeStyle}">
                                        <TextBlock
                                            Text="{x:Bind FileExtension, Mode=OneWay}"
                                            FontSize="11"
                                            FontWeight="SemiBold"
                                            Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" />
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    </Grid>
                </Border>

                <!-- Left pane toolbar -->
                <CommandBar
                    Grid.Row="2"
                    DefaultLabelPosition="Collapsed"
                    IsOpen="False"
                    AutomationProperties.Name="Source files toolbar">
                    <AppBarButton Icon="Sort" ToolTipService.ToolTip="Sort"
                                  Command="{x:Bind ViewModel.SortOriginalFilesCommand}"
                                  AutomationProperties.Name="Sort files" />
                    <AppBarButton Icon="Delete" ToolTipService.ToolTip="Remove selected"
                                  Command="{x:Bind ViewModel.RemoveSelectedCommand}"
                                  AutomationProperties.Name="Remove selected" />
                    <AppBarButton Icon="OpenLocal" Label="Load" ToolTipService.ToolTip="Load files or folder (Ctrl+O)"
                                  AutomationProperties.Name="Load files or folder">
                        <AppBarButton.Flyout>
                            <MenuFlyout>
                                <MenuFlyoutItem Text="Files..." Command="{x:Bind ViewModel.AddFilesCommand}"
                                                AutomationProperties.Name="Load individual files">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE8E5;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem Text="Folder..." Command="{x:Bind ViewModel.AddFolderCommand}"
                                                AutomationProperties.Name="Load folder">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE8B7;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyout>
                        </AppBarButton.Flyout>
                    </AppBarButton>
                    <AppBarButton Icon="Refresh" ToolTipService.ToolTip="Refresh (F5)"
                                  Command="{x:Bind ViewModel.RefreshCommand}"
                                  AutomationProperties.Name="Refresh" />
                    <AppBarSeparator />
                    <AppBarButton ToolTipService.ToolTip="MediaInfo Inspector"
                                  Click="MediaInfoInspector_Click"
                                  AutomationProperties.Name="MediaInfo Inspector">
                        <AppBarButton.Icon>
                            <FontIcon Glyph="&#xE946;" />
                        </AppBarButton.Icon>
                    </AppBarButton>
                </CommandBar>
            </Grid>

            <!-- CENTER GUTTER: Match + Rename buttons -->
            <StackPanel
                Grid.Column="1"
                VerticalAlignment="Center"
                Spacing="16"
                Padding="12,0"
                AutomationProperties.Name="Actions">

                <SplitButton
                    Width="72" Height="72"
                    Click="MatchButton_Click"
                    ToolTipService.ToolTip="Match files (click for auto, dropdown for specific datasource)"
                    AutomationProperties.Name="Match files">
                    <StackPanel Spacing="4">
                        <FontIcon Glyph="&#xE8AF;" FontSize="24" HorizontalAlignment="Center" />
                        <TextBlock Text="Match" HorizontalAlignment="Center" FontSize="11" />
                    </StackPanel>
                    <SplitButton.Flyout>
                        <MenuFlyout Placement="Bottom">
                            <MenuFlyoutItem Text="Automatic" Command="{x:Bind ViewModel.MatchWithDatasourceCommand}" CommandParameter="auto" />
                            <MenuFlyoutSeparator />
                            <MenuFlyoutSubItem Text="Episode Mode">
                                <MenuFlyoutItem Text="TheTVDB" Command="{x:Bind ViewModel.MatchWithDatasourceCommand}" CommandParameter="tvdb" />
                                <MenuFlyoutItem Text="AniDB" Command="{x:Bind ViewModel.MatchWithDatasourceCommand}" CommandParameter="anidb" />
                                <MenuFlyoutItem Text="TheMovieDB" Command="{x:Bind ViewModel.MatchWithDatasourceCommand}" CommandParameter="tmdb_tv" />
                                <MenuFlyoutItem Text="TVmaze" Command="{x:Bind ViewModel.MatchWithDatasourceCommand}" CommandParameter="tvmaze" />
                            </MenuFlyoutSubItem>
                            <MenuFlyoutSubItem Text="Movie Mode">
                                <MenuFlyoutItem Text="TheMovieDB" Command="{x:Bind ViewModel.MatchWithDatasourceCommand}" CommandParameter="tmdb" />
                                <MenuFlyoutItem Text="OMDb" Command="{x:Bind ViewModel.MatchWithDatasourceCommand}" CommandParameter="omdb" />
                            </MenuFlyoutSubItem>
                            <MenuFlyoutSubItem Text="Music Mode">
                                <MenuFlyoutItem Text="AcoustID" Command="{x:Bind ViewModel.MatchWithDatasourceCommand}" CommandParameter="acoustid" />
                                <MenuFlyoutItem Text="ID3 Tags" Command="{x:Bind ViewModel.MatchWithDatasourceCommand}" CommandParameter="id3" />
                            </MenuFlyoutSubItem>
                            <MenuFlyoutSeparator />
                            <MenuFlyoutSubItem Text="Smart Mode">
                                <MenuFlyoutItem Text="Attributes" Command="{x:Bind ViewModel.MatchWithDatasourceCommand}" CommandParameter="xattr" />
                            </MenuFlyoutSubItem>
                            <MenuFlyoutSeparator />
                            <MenuFlyoutItem Text="Edit Format..." Command="{x:Bind ViewModel.EditFormatCommand}" />
                            <MenuFlyoutItem Text="Preferences..." Command="{x:Bind ViewModel.OpenPreferencesCommand}" />
                        </MenuFlyout>
                    </SplitButton.Flyout>
                </SplitButton>

                <Button
                    Width="72" Height="72"
                    Command="{x:Bind ViewModel.RenameCommand}"
                    ToolTipService.ToolTip="Rename files using matched metadata"
                    AutomationProperties.Name="Rename files">
                    <StackPanel Spacing="4">
                        <FontIcon Glyph="&#xE8AC;" FontSize="24" HorizontalAlignment="Center" />
                        <TextBlock Text="Rename" HorizontalAlignment="Center" FontSize="11" />
                    </StackPanel>
                </Button>
            </StackPanel>

            <!-- RIGHT PANE: Matched Names -->
            <Grid Grid.Column="2" RowSpacing="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Header -->
                <TextBlock
                    Grid.Row="0"
                    Text="Matched Names"
                    Style="{StaticResource BodyStrongTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Padding="8,4" />

                <!-- Matched files list or placeholder -->
                <Border Grid.Row="1"
                        BorderBrush="{x:Bind ViewModel.ActiveMatchMode, Mode=OneWay, Converter={StaticResource MatchModeBrush}}"
                        BorderThickness="1"
                        CornerRadius="4">
                <Grid>
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                        Text="Click Match to generate new names"
                        Visibility="{x:Bind ViewModel.HasNoMatchedFiles, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />

                    <ListView
                        ItemsSource="{x:Bind ViewModel.MatchedFiles, Mode=OneWay}"
                        SelectionMode="None"
                        Visibility="{x:Bind ViewModel.HasMatchedFiles, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                        AutomationProperties.Name="New names list">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="vm:FileItemViewModel">
                                <Grid Padding="8,4" ColumnSpacing="8"
                                      AutomationProperties.Name="{x:Bind AutomationName, Mode=OneWay}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        Grid.Column="0"
                                        VerticalAlignment="Center"
                                        Text="{x:Bind NewFileName, Mode=OneWay}"
                                        Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                        TextTrimming="CharacterEllipsis" />
                                    <Border Grid.Column="1" Style="{StaticResource ExtensionBadgeStyle}">
                                        <TextBlock
                                            Text="{x:Bind FileExtension, Mode=OneWay}"
                                            FontSize="11"
                                            FontWeight="SemiBold"
                                            Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" />
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
                </Border>

                <!-- Right pane toolbar -->
                <CommandBar
                    Grid.Row="2"
                    DefaultLabelPosition="Collapsed"
                    IsOpen="False"
                    AutomationProperties.Name="Matched names toolbar">
                    <AppBarButton Icon="Sort" ToolTipService.ToolTip="Sort"
                                  Command="{x:Bind ViewModel.SortMatchedFilesCommand}"
                                  AutomationProperties.Name="Sort matched files" />
                    <AppBarButton Icon="Delete" ToolTipService.ToolTip="Clear matches"
                                  Command="{x:Bind ViewModel.ClearMatchesCommand}"
                                  AutomationProperties.Name="Clear matched files" />
                    <AppBarButton Icon="Download" Label="Fetch Data" ToolTipService.ToolTip="Fetch metadata"
                                  Command="{x:Bind ViewModel.FetchDataCommand}"
                                  AutomationProperties.Name="Fetch metadata" />
                </CommandBar>
            </Grid>
        </Grid>

        <!-- Mode Panels -->
        <controls:EpisodesPanel Grid.Row="4" x:Name="EpisodesPanel" Visibility="Collapsed" />
        <controls:SubtitlePanel Grid.Row="4" x:Name="SubtitlesPanel" Visibility="Collapsed" />
        <controls:SfvPanel Grid.Row="4" x:Name="SfvPanel" Visibility="Collapsed" />
        <controls:FilterPanel Grid.Row="4" x:Name="FilterPanel" Visibility="Collapsed" />
        <controls:ListPanel Grid.Row="4" x:Name="ListPanel" Visibility="Collapsed" />

        <!-- Status Bar -->
        <Grid
            Grid.Row="5"
            Padding="12,8"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            CornerRadius="4"
            AutomationProperties.Name="Status bar"
            AutomationProperties.LiveSetting="Polite">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock
                VerticalAlignment="Center"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" />
            <TextBlock
                Grid.Column="1"
                VerticalAlignment="Center"
                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                Margin="16,0"
                Text="{x:Bind ViewModel.FileCountDisplay, Mode=OneWay}" />
            <ProgressRing
                Grid.Column="2"
                Width="20"
                Height="20"
                IsActive="{x:Bind ViewModel.IsProcessing, Mode=OneWay}"
                AutomationProperties.Name="Processing" />
        </Grid>
    </Grid>
</Page>
