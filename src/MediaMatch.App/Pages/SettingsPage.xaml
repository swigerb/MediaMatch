<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="MediaMatch.App.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:MediaMatch.App.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:MediaMatch.App.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    AutomationProperties.Name="Settings">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
    </Page.Resources>

    <ScrollViewer>
        <StackPanel
            MaxWidth="800"
            Padding="24,16,24,24"
            Spacing="24">

            <!-- Header -->
            <TextBlock
                Style="{StaticResource TitleTextBlockStyle}"
                Text="Settings"
                AutomationProperties.HeadingLevel="Level1" />

            <!-- Welcome Banner (first-run only) -->
            <InfoBar
                IsClosable="True"
                IsOpen="{x:Bind ViewModel.ShowWelcomeBanner, Mode=TwoWay}"
                Message="MediaMatch works out of the box with local metadata files. Add API keys below to unlock online providers (TMDb, TVDb, OpenSubtitles) for richer matching results."
                Severity="Success"
                Title="Welcome to MediaMatch!"
                Visibility="{x:Bind ViewModel.ShowWelcomeBanner, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                AutomationProperties.Name="Welcome banner" />

            <!-- Appearance -->
            <StackPanel Spacing="16">
                <TextBlock
                    Style="{StaticResource SubtitleTextBlockStyle}"
                    Text="Appearance"
                    AutomationProperties.HeadingLevel="Level2" />

                <ComboBox
                    Header="Theme"
                    TabIndex="1"
                    ItemsSource="{x:Bind ViewModel.ThemeOptions}"
                    SelectedIndex="{x:Bind ViewModel.SelectedThemeIndex, Mode=TwoWay}"
                    AutomationProperties.Name="Theme selector" />

                <StackPanel Spacing="4">
                    <TextBlock Text="Font Size" />
                    <ComboBox
                        TabIndex="2"
                        ItemsSource="{x:Bind ViewModel.FontScaleOptions}"
                        SelectedIndex="{x:Bind ViewModel.SelectedFontScaleIndex, Mode=TwoWay}"
                        AutomationProperties.Name="Font size selector" />
                </StackPanel>

                <!-- Font Scale Preview -->
                <StackPanel Spacing="8">
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="Preview" />
                    <Border
                        Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                        CornerRadius="4">
                        <StackPanel Spacing="6">
                            <TextBlock
                                FontSize="{x:Bind ViewModel.FontPreviewSize, Mode=OneWay}"
                                Text="{x:Bind ViewModel.FontPreviewText, Mode=OneWay}"
                                TextWrapping="Wrap" />
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Text="{x:Bind ViewModel.FontPreviewCaption, Mode=OneWay}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>

            <!-- API Keys -->
            <StackPanel Spacing="16">
                <TextBlock
                    Style="{StaticResource SubtitleTextBlockStyle}"
                    Text="API Keys"
                    AutomationProperties.HeadingLevel="Level2" />

                <Grid ColumnSpacing="8" RowSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <PasswordBox
                        Grid.Row="0"
                        Grid.Column="0"
                        TabIndex="3"
                        Header="TMDB API Key"
                        Password="{x:Bind ViewModel.TmdbApiKey, Mode=TwoWay}"
                        PlaceholderText="Enter your TMDB API key"
                        AutomationProperties.Name="TMDB API Key"
                        AutomationProperties.HelpText="Enter your TMDB API key for movie metadata lookup" />
                    <Button
                        Grid.Row="0"
                        Grid.Column="1"
                        TabIndex="4"
                        VerticalAlignment="Bottom"
                        Command="{x:Bind ViewModel.ClearTmdbApiKeyCommand}"
                        Content="Clear"
                        AutomationProperties.Name="Clear TMDB API Key" />

                    <PasswordBox
                        Grid.Row="1"
                        Grid.Column="0"
                        TabIndex="5"
                        Header="TVDB API Key"
                        Password="{x:Bind ViewModel.TvdbApiKey, Mode=TwoWay}"
                        PlaceholderText="Enter your TVDB API key"
                        AutomationProperties.Name="TVDB API Key"
                        AutomationProperties.HelpText="Enter your TVDB API key for TV series metadata" />
                    <Button
                        Grid.Row="1"
                        Grid.Column="1"
                        TabIndex="6"
                        VerticalAlignment="Bottom"
                        Command="{x:Bind ViewModel.ClearTvdbApiKeyCommand}"
                        Content="Clear"
                        AutomationProperties.Name="Clear TVDB API Key" />

                    <PasswordBox
                        Grid.Row="2"
                        Grid.Column="0"
                        TabIndex="7"
                        Header="OpenSubtitles API Key"
                        Password="{x:Bind ViewModel.OpenSubtitlesApiKey, Mode=TwoWay}"
                        PlaceholderText="Enter your OpenSubtitles API key"
                        AutomationProperties.Name="OpenSubtitles API Key"
                        AutomationProperties.HelpText="Enter your OpenSubtitles API key for subtitle downloads" />
                </Grid>
            </StackPanel>

            <!-- Rename Patterns -->
            <StackPanel Spacing="16">
                <TextBlock
                    Style="{StaticResource SubtitleTextBlockStyle}"
                    Text="Rename Patterns"
                    AutomationProperties.HeadingLevel="Level2" />

                <TextBox
                    TabIndex="8"
                    Header="Movie Pattern"
                    PlaceholderText="{}{Name} ({Year})/{Name} ({Year}){extension}"
                    Text="{x:Bind ViewModel.MovieRenamePattern, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    AutomationProperties.Name="Movie rename pattern"
                    AutomationProperties.HelpText="Template for renaming movie files. Use {Name}, {Year}, {extension} placeholders." />

                <TextBox
                    TabIndex="9"
                    Header="Series Pattern"
                    PlaceholderText="{}{SeriesName}/Season {Season}/..."
                    Text="{x:Bind ViewModel.SeriesRenamePattern, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    AutomationProperties.Name="Series rename pattern"
                    AutomationProperties.HelpText="Template for renaming TV series files. Use {SeriesName}, {Season}, {Episode}, {Title} placeholders." />

                <TextBox
                    TabIndex="10"
                    Header="Anime Pattern"
                    PlaceholderText="{}{SeriesName}/Season {Season}/..."
                    Text="{x:Bind ViewModel.AnimeRenamePattern, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    AutomationProperties.Name="Anime rename pattern"
                    AutomationProperties.HelpText="Template for renaming anime files. Uses same placeholders as series pattern." />

                <InfoBar
                    IsClosable="False"
                    IsOpen="True"
                    Message="{x:Bind ViewModel.RenamePreview, Mode=OneWay}"
                    Severity="Informational"
                    Title="Preview"
                    AutomationProperties.Name="Rename pattern preview"
                    AutomationProperties.LiveSetting="Polite" />
            </StackPanel>

            <!-- Output Folders -->
            <StackPanel Spacing="16">
                <TextBlock
                    Style="{StaticResource SubtitleTextBlockStyle}"
                    Text="Output Folders"
                    AutomationProperties.HeadingLevel="Level2" />

                <Grid ColumnSpacing="8" RowSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBox
                        Grid.Row="0"
                        Grid.Column="0"
                        TabIndex="11"
                        Header="Movies Output Folder"
                        IsReadOnly="True"
                        PlaceholderText="Select a folder..."
                        Text="{x:Bind ViewModel.MovieOutputFolder, Mode=OneWay}"
                        AutomationProperties.Name="Movies output folder path" />
                    <Button
                        Grid.Row="0"
                        Grid.Column="1"
                        TabIndex="12"
                        VerticalAlignment="Bottom"
                        Command="{x:Bind ViewModel.BrowseMovieOutputFolderCommand}"
                        Content="Browse..."
                        AutomationProperties.Name="Browse for movies output folder" />

                    <TextBox
                        Grid.Row="1"
                        Grid.Column="0"
                        TabIndex="13"
                        Header="Series Output Folder"
                        IsReadOnly="True"
                        PlaceholderText="Select a folder..."
                        Text="{x:Bind ViewModel.SeriesOutputFolder, Mode=OneWay}"
                        AutomationProperties.Name="Series output folder path" />
                    <Button
                        Grid.Row="1"
                        Grid.Column="1"
                        TabIndex="14"
                        VerticalAlignment="Bottom"
                        Command="{x:Bind ViewModel.BrowseSeriesOutputFolderCommand}"
                        Content="Browse..."
                        AutomationProperties.Name="Browse for series output folder" />
                </Grid>
            </StackPanel>

            <!-- Actions -->
            <StackPanel
                HorizontalAlignment="Left"
                Orientation="Horizontal"
                Spacing="8">
                <Button
                    TabIndex="15"
                    Command="{x:Bind ViewModel.SaveSettingsCommand}"
                    Content="Save Settings"
                    Style="{StaticResource AccentButtonStyle}"
                    AutomationProperties.Name="Save all settings" />
                <Button
                    TabIndex="16"
                    Command="{x:Bind ViewModel.ClearCacheCommand}"
                    Content="Clear Cache"
                    AutomationProperties.Name="Clear metadata cache" />
            </StackPanel>

            <!-- Status -->
            <TextBlock
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                AutomationProperties.LiveSetting="Polite" />
        </StackPanel>
    </ScrollViewer>
</Page>
