<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="MediaMatch.App.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:MediaMatch.App.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:MediaMatch.App.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
    </Page.Resources>

    <ScrollViewer>
        <StackPanel
            MaxWidth="800"
            Padding="24,16,24,24"
            Spacing="24">

            <!-- Header -->
            <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Settings" />

            <!-- Welcome Banner (first-run only) -->
            <InfoBar
                IsClosable="True"
                IsOpen="{x:Bind ViewModel.ShowWelcomeBanner, Mode=TwoWay}"
                Message="Configure your API keys and output folders to get started. You can always come back to this page later."
                Severity="Success"
                Title="Welcome to MediaMatch!"
                Visibility="{x:Bind ViewModel.ShowWelcomeBanner, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />

            <!-- API Keys -->
            <StackPanel Spacing="16">
                <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="API Keys" />

                <Grid ColumnSpacing="8" RowSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <PasswordBox
                        Grid.Row="0"
                        Grid.Column="0"
                        Header="TMDB API Key"
                        Password="{x:Bind ViewModel.TmdbApiKey, Mode=TwoWay}"
                        PlaceholderText="Enter your TMDB API key" />
                    <Button
                        Grid.Row="0"
                        Grid.Column="1"
                        VerticalAlignment="Bottom"
                        Command="{x:Bind ViewModel.ClearTmdbApiKeyCommand}"
                        Content="Clear" />

                    <PasswordBox
                        Grid.Row="1"
                        Grid.Column="0"
                        Header="TVDB API Key"
                        Password="{x:Bind ViewModel.TvdbApiKey, Mode=TwoWay}"
                        PlaceholderText="Enter your TVDB API key" />
                    <Button
                        Grid.Row="1"
                        Grid.Column="1"
                        VerticalAlignment="Bottom"
                        Command="{x:Bind ViewModel.ClearTvdbApiKeyCommand}"
                        Content="Clear" />

                    <PasswordBox
                        Grid.Row="2"
                        Grid.Column="0"
                        Header="OpenSubtitles API Key"
                        Password="{x:Bind ViewModel.OpenSubtitlesApiKey, Mode=TwoWay}"
                        PlaceholderText="Enter your OpenSubtitles API key" />
                </Grid>
            </StackPanel>

            <!-- Rename Patterns -->
            <StackPanel Spacing="16">
                <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="Rename Patterns" />

                <TextBox
                    Header="Movie Pattern"
                    PlaceholderText="{}{Name} ({Year})/{Name} ({Year}){extension}"
                    Text="{x:Bind ViewModel.MovieRenamePattern, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <TextBox
                    Header="Series Pattern"
                    PlaceholderText="{}{SeriesName}/Season {Season}/..."
                    Text="{x:Bind ViewModel.SeriesRenamePattern, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <TextBox
                    Header="Anime Pattern"
                    PlaceholderText="{}{SeriesName}/Season {Season}/..."
                    Text="{x:Bind ViewModel.AnimeRenamePattern, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <InfoBar
                    IsClosable="False"
                    IsOpen="True"
                    Message="{x:Bind ViewModel.RenamePreview, Mode=OneWay}"
                    Severity="Informational"
                    Title="Preview" />
            </StackPanel>

            <!-- Output Folders -->
            <StackPanel Spacing="16">
                <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="Output Folders" />

                <Grid ColumnSpacing="8" RowSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBox
                        Grid.Row="0"
                        Grid.Column="0"
                        Header="Movies Output Folder"
                        IsReadOnly="True"
                        PlaceholderText="Select a folder..."
                        Text="{x:Bind ViewModel.MovieOutputFolder, Mode=OneWay}" />
                    <Button
                        Grid.Row="0"
                        Grid.Column="1"
                        VerticalAlignment="Bottom"
                        Command="{x:Bind ViewModel.BrowseMovieOutputFolderCommand}"
                        Content="Browse..." />

                    <TextBox
                        Grid.Row="1"
                        Grid.Column="0"
                        Header="Series Output Folder"
                        IsReadOnly="True"
                        PlaceholderText="Select a folder..."
                        Text="{x:Bind ViewModel.SeriesOutputFolder, Mode=OneWay}" />
                    <Button
                        Grid.Row="1"
                        Grid.Column="1"
                        VerticalAlignment="Bottom"
                        Command="{x:Bind ViewModel.BrowseSeriesOutputFolderCommand}"
                        Content="Browse..." />
                </Grid>
            </StackPanel>

            <!-- Actions -->
            <StackPanel
                HorizontalAlignment="Left"
                Orientation="Horizontal"
                Spacing="8">
                <Button
                    Command="{x:Bind ViewModel.SaveSettingsCommand}"
                    Content="Save Settings"
                    Style="{StaticResource AccentButtonStyle}" />
                <Button
                    Command="{x:Bind ViewModel.ClearCacheCommand}"
                    Content="Clear Cache" />
            </StackPanel>

            <!-- Status -->
            <TextBlock
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" />
        </StackPanel>
    </ScrollViewer>
</Page>
