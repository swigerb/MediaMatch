<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="MediaMatch.App.Pages.HistoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:MediaMatch.App.Pages"
    xmlns:vm="using:MediaMatch.App.ViewModels"
    xmlns:models="using:MediaMatch.Core.Models"
    xmlns:converters="using:MediaMatch.App.Converters"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    AutomationProperties.Name="Rename History">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
    </Page.Resources>

    <Grid Padding="24,16,24,16" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock
            Grid.Row="0"
            Style="{StaticResource TitleTextBlockStyle}"
            Text="Rename History"
            AutomationProperties.HeadingLevel="Level1" />

        <!-- Toolbar -->
        <CommandBar
            Grid.Row="1"
            DefaultLabelPosition="Right"
            IsOpen="False"
            AutomationProperties.Name="History operations toolbar">
            <AppBarButton
                Command="{x:Bind ViewModel.RevertSelectedCommand}"
                Icon="Undo"
                Label="Revert Selected"
                TabIndex="1"
                ToolTipService.ToolTip="Revert the selected session"
                AutomationProperties.Name="Revert selected session" />
            <AppBarButton
                Command="{x:Bind ViewModel.ExportCommand}"
                Icon="Save"
                Label="Export"
                TabIndex="2"
                ToolTipService.ToolTip="Export history as JSON"
                AutomationProperties.Name="Export history as JSON" />
            <AppBarSeparator />
            <AppBarButton
                Command="{x:Bind ViewModel.ClearHistoryCommand}"
                Icon="Delete"
                Label="Clear History"
                TabIndex="3"
                ToolTipService.ToolTip="Clear all rename history"
                AutomationProperties.Name="Clear all rename history" />
        </CommandBar>

        <!-- Main content: master-detail or empty state -->
        <Grid Grid.Row="2">
            <!-- Empty state -->
            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="12"
                Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                AutomationProperties.Name="No history">
                <FontIcon
                    HorizontalAlignment="Center"
                    FontSize="48"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Glyph="&#xE81C;" />
                <TextBlock
                    HorizontalAlignment="Center"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{StaticResource SubtitleTextBlockStyle}"
                    Text="No rename history" />
                <TextBlock
                    HorizontalAlignment="Center"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                    Text="Rename operations will appear here after you process files." />
            </StackPanel>

            <!-- Master-detail layout -->
            <Grid
                ColumnSpacing="16"
                Visibility="{x:Bind ViewModel.HasHistory, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Left panel: Session list -->
                <Grid Grid.Column="0" RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock
                        Grid.Row="0"
                        Style="{StaticResource SubtitleTextBlockStyle}"
                        Text="Sessions"
                        AutomationProperties.HeadingLevel="Level2" />

                    <ListView
                        Grid.Row="1"
                        ItemsSource="{x:Bind ViewModel.Sessions, Mode=OneWay}"
                        SelectedItem="{x:Bind ViewModel.SelectedSession, Mode=TwoWay}"
                        SelectionMode="Single"
                        TabIndex="10"
                        AutomationProperties.Name="Rename session list">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="vm:HistorySessionViewModel">
                                <Grid
                                    Padding="12,10"
                                    ColumnSpacing="12"
                                    AutomationProperties.Name="{x:Bind Summary}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <!-- Media type icon -->
                                    <FontIcon
                                        Grid.Column="0"
                                        Grid.RowSpan="2"
                                        VerticalAlignment="Center"
                                        FontSize="20"
                                        Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                        Glyph="&#xE8B7;" />

                                    <!-- Date/time -->
                                    <TextBlock
                                        Grid.Row="0"
                                        Grid.Column="1"
                                        Text="{x:Bind FormattedTimestamp}"
                                        Style="{StaticResource BodyStrongTextBlockStyle}" />

                                    <!-- Summary -->
                                    <StackPanel
                                        Grid.Row="1"
                                        Grid.Column="1"
                                        Orientation="Horizontal"
                                        Spacing="8">
                                        <TextBlock
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Text="{x:Bind Summary}" />
                                        <TextBlock
                                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                            Text="·" />
                                        <TextBlock
                                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                            Text="{x:Bind MediaType}" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>

                <!-- Right panel: Session detail -->
                <Grid Grid.Column="1" RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock
                        Grid.Row="0"
                        Style="{StaticResource SubtitleTextBlockStyle}"
                        Text="Details"
                        AutomationProperties.HeadingLevel="Level2" />

                    <ListView
                        Grid.Row="1"
                        ItemsSource="{x:Bind ViewModel.SelectedSessionEntries, Mode=OneWay}"
                        SelectionMode="None"
                        TabIndex="20"
                        AutomationProperties.Name="Session detail entries">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:UndoEntry">
                                <Grid
                                    Padding="12,8"
                                    RowSpacing="4"
                                    AutomationProperties.Name="Rename entry">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <!-- Original → New file names -->
                                    <StackPanel
                                        Grid.Row="0"
                                        Orientation="Horizontal"
                                        Spacing="8">
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            Text="{x:Bind OriginalPath}"
                                            TextTrimming="CharacterEllipsis"
                                            MaxWidth="400" />
                                        <FontIcon
                                            VerticalAlignment="Center"
                                            FontSize="12"
                                            Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                            Glyph="&#xE72A;" />
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                            Text="{x:Bind NewPath}"
                                            TextTrimming="CharacterEllipsis"
                                            MaxWidth="400" />
                                    </StackPanel>

                                    <!-- Timestamp + media type -->
                                    <StackPanel
                                        Grid.Row="1"
                                        Orientation="Horizontal"
                                        Spacing="8">
                                        <TextBlock
                                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                            Style="{StaticResource CaptionTextBlockStyle}"
                                            Text="{x:Bind MediaType}" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Grid>
        </Grid>

        <!-- Status Bar -->
        <Grid
            Grid.Row="3"
            Padding="12,8"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            CornerRadius="4"
            AutomationProperties.Name="Status bar"
            AutomationProperties.LiveSetting="Polite">
            <TextBlock
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                AutomationProperties.LiveSetting="Polite" />
        </Grid>
    </Grid>
</Page>
