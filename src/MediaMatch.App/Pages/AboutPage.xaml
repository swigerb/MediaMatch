<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="MediaMatch.App.Pages.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:MediaMatch.App.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    AutomationProperties.Name="About Media Match">

    <ScrollViewer>
        <StackPanel
            MaxWidth="600"
            Padding="24,16,24,24"
            Spacing="24">

            <!-- Header with logo -->
            <StackPanel Spacing="12" HorizontalAlignment="Center">
                <Image
                    Source="ms-appx:///Assets/MediaMatch_Logo.png"
                    MaxWidth="520"
                    MaxHeight="280"
                    Stretch="Uniform"
                    AutomationProperties.Name="Media Match logo" />
                <TextBlock
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{StaticResource SubtitleTextBlockStyle}"
                    Text="{x:Bind ViewModel.Version}"
                    HorizontalAlignment="Center" />
            </StackPanel>

            <!-- Description -->
            <TextBlock
                Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                Text="{x:Bind ViewModel.Description}"
                TextWrapping="WrapWholeWords" />

            <!-- Links -->
            <StackPanel Spacing="8">
                <TextBlock
                    Style="{StaticResource SubtitleTextBlockStyle}"
                    Text="Links"
                    AutomationProperties.HeadingLevel="Level2" />
                <HyperlinkButton
                    TabIndex="1"
                    Command="{x:Bind ViewModel.OpenGitHubCommand}"
                    Content="GitHub Repository"
                    AutomationProperties.Name="Open GitHub repository in browser" />
            </StackPanel>

            <!-- License -->
            <StackPanel Spacing="8">
                <TextBlock
                    Style="{StaticResource SubtitleTextBlockStyle}"
                    Text="License"
                    AutomationProperties.HeadingLevel="Level2" />
                <TextBlock
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="{x:Bind ViewModel.License}" />
                <TextBlock
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                    Text="{x:Bind ViewModel.Copyright}" />
            </StackPanel>

            <!-- Credits -->
            <StackPanel Spacing="8">
                <TextBlock
                    Style="{StaticResource SubtitleTextBlockStyle}"
                    Text="Credits"
                    AutomationProperties.HeadingLevel="Level2" />
                <TextBlock
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="Built with WinUI 3, .NET 10, and the Windows App SDK."
                    TextWrapping="WrapWholeWords" />
                <TextBlock
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="Inspired by FileBot — the original media renaming tool."
                    TextWrapping="WrapWholeWords" />
                <TextBlock
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                    Text="Metadata powered by TMDB and TVDB."
                    TextWrapping="WrapWholeWords" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
